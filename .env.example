# Local server. Keep real secrets in the deployment secret manager, never in this file.
# A public production process must also pass `pnpm run preflight:production`; see docs/PRODUCTION_DEPLOYMENT.md.
HOST=127.0.0.1
PORT=4173
TRUST_PROXY=false
# Required only when TRUST_PROXY=true. List the immediate reverse proxy's exact IP/CIDR ranges;
# that proxy must remove incoming forwarding headers and write exactly one X-Forwarded-For IP.
TRUSTED_PROXY_CIDRS=
APP_ORIGIN=http://127.0.0.1:4173
# Store private pilot records outside OneDrive, Dropbox, Google Drive and iCloud. Use an absolute non-synchronised path.
DATA_DIR=
# Keep false for a single-user local pilot. Set true wherever localhost access must also present ADMIN_KEY.
ADMIN_REQUIRE_KEY=false
ADMIN_KEY=

# PostgreSQL marketplace database (required before authenticated production use).
MARKETPLACE_ENABLED=false
# Absolute path/file URL to a deployment-owned monitoring/optional-ETA module exporting createMarketplaceDeploymentAdapters({ env }).
MARKETPLACE_ADAPTER_MODULE=
DATABASE_URL=postgresql://tideway_app:replace-me@127.0.0.1:5432/tideway
# Separate restricted scheduler credential; never use this connection for web requests.
WORKER_DATABASE_URL=postgresql://tideway_worker:replace-me@127.0.0.1:5432/tideway
WORKER_DATABASE_POOL_MAX=5
# The maintenance scheduler is a separate process. Keep every capability false until its staging gate passes.
MARKETPLACE_WORKER_ENABLED=false
WORKER_EMAIL_ENABLED=false
WORKER_MEDIA_ENABLED=false
WORKER_AUTOMATIC_DISPATCH_ENABLED=false
DATABASE_POOL_MAX=10
SESSION_SECRET=replace-with-at-least-32-random-characters
AUTH_TOKEN_SECRET=replace-with-a-different-32-character-random-secret
DATA_ENCRYPTION_KEY=replace-with-a-third-distinct-32-character-random-secret

# Email/password verification, password reset and privacy-minimal booking notifications.
# Use a credentialed smtp/smtps hostname. Paths, query options and fragments are rejected.
SMTP_URL=smtps://user:password@smtp.example.com:465
EMAIL_FROM=Homle <no-reply@homle.co.uk>

# OAuth providers. Configure a complete pair/set or leave the provider entirely blank.
# Google Web redirect URI must exactly equal:
#   https://homle.co.uk/api/marketplace/auth/google/callback
# Select only the providers being activated, then run `pnpm run preflight:authentication` before staging.
TIDEWAY_EXPECT_SOCIAL_PROVIDERS=google
# Exact eight-character sourceCommit from the verified package manifest. Authentication activation and the worker refuse a different or unidentified runtime.
TIDEWAY_EXPECT_RELEASE=
# Facebook remains unavailable until mailbox verification plus the signed Meta data-deletion callback pass real PostgreSQL, SMTP, HTTPS and Meta app staging.
# Meta data-deletion callback URL:
#   https://homle.co.uk/api/marketplace/auth/facebook/data-deletion
# Public confirmation/status page:
#   https://homle.co.uk/facebook-data-deletion
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Pin the exact Graph API version shown as supported by the Homle Meta app (for example vNN.N); do not guess or silently float it.
FACEBOOK_GRAPH_API_VERSION=

# Private image storage. Use restricted server credentials, never browser credentials.
OBJECT_STORAGE_ENDPOINT=https://objects.example.com
OBJECT_STORAGE_BUCKET=tideway-private
OBJECT_STORAGE_REGION=eu-west-2
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
# Use true only when the selected S3-compatible provider requires path-style bucket URLs.
OBJECT_STORAGE_FORCE_PATH_STYLE=false

# Map provider is introduced with the tracking phase. Browser tokens must be origin-restricted.
MAP_PROVIDER=none
MAP_PUBLIC_TOKEN=

# Private booking economics. Configure every value together after founder approval; these never belong in browser code.
BOOKING_TARGET_MARGIN_BPS=
BOOKING_LABOUR_ON_COST_BPS=
BOOKING_PAYMENT_FEE_BPS=
BOOKING_PAYMENT_FEE_FIXED_PENCE=
BOOKING_TRAVEL_COST_PENCE=
BOOKING_SUPPLIES_COST_PENCE=
BOOKING_OTHER_COST_PENCE=
BOOKING_INVITATION_TTL_MINUTES=

# Stripe Connect preparation. Keep false until the founder-approved test platform, webhook endpoint and staging database all pass.
# This adapter rejects live keys. Store both secrets in the deployment secret manager, never in this file or browser code.
PAYMENTS_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
